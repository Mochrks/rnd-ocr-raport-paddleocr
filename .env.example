# ─────────────────────────────────────────────────
# OCR Service — Environment Configuration Example
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────

# Application
DEBUG=false
APP_VERSION=2.0.0

# Logging
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Uncomment to also write logs to a file:
# LOG_FILE=logs/ocr_service.log

# File Upload
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=20

# OCR Engine
OCR_LANG=en
OCR_DET_THRESH=0.3
OCR_BOX_THRESH=0.4
OCR_USE_TEXTLINE_ORIENTATION=true
# Set to true to warm up the OCR engines on server startup.
# This eliminates first-request latency (~5-15s cold start) at the cost
# of slightly longer server boot time.
OCR_WARMUP_ON_STARTUP=true

# Performance Tuning
# Enable Intel MKLDNN acceleration for CPU inference (recommended)
OCR_USE_MKLDNN=true
# Number of CPU threads for PaddlePaddle inference
OCR_CPU_THREADS=4
# Enable GPU acceleration (requires paddlepaddle-gpu)
OCR_USE_GPU=false

# Image Processing
# Set to false to skip denoising for high-quality digital PDFs
PREPROCESSING_DENOISE_ENABLED=true
# DPI multiplier when rendering PDF pages (1.5 = 150 DPI, good balance)
PDF_RENDER_SCALE=1.5
# Maximum image width in pixels (larger images are downscaled)
IMAGE_MAX_WIDTH=1200
# Maximum total pixel count (larger images are downscaled proportionally)
IMAGE_MAX_PIXELS=2000000

# Subject Matching
FUZZY_MATCH_THRESHOLD=60
Y_CLUSTER_TOLERANCE=20
SCORE_ZONE_FALLBACK_RATIO=0.35

# Redis / Celery Task Queue
REDIS_URL=redis://localhost:6379/0
