# ─────────────────────────────────────────────────
# OCR Service — Environment Configuration Example
# Copy to .env dan isi semua value.
# File ini AMAN di-push ke GitHub — tidak ada value sensitif.
# ─────────────────────────────────────────────────

# Application
APP_TITLE=
APP_DESCRIPTION=
APP_VERSION=
DEBUG=

# CORS — gunakan ["*"] untuk allow all, atau spesifik: ["http://localhost:3000","https://yourdomain.com"]
CORS_ORIGINS=
CORS_ALLOW_CREDENTIALS=
CORS_ALLOW_METHODS=
CORS_ALLOW_HEADERS=

# File Upload
UPLOAD_DIR=
MAX_UPLOAD_SIZE_MB=
ALLOWED_EXTENSIONS=

# OCR Engine
OCR_LANG=
OCR_DET_THRESH=
OCR_BOX_THRESH=
OCR_USE_TEXTLINE_ORIENTATION=
OCR_WARMUP_ON_STARTUP=
OCR_USE_GPU=
OCR_USE_MKLDNN=
OCR_CPU_THREADS=

# Image Processing
PREPROCESSING_DENOISE_ENABLED=
PDF_RENDER_SCALE=
IMAGE_MAX_WIDTH=
IMAGE_MAX_PIXELS=

# Subject Matching
FUZZY_MATCH_THRESHOLD=
Y_CLUSTER_TOLERANCE=
SCORE_ZONE_FALLBACK_RATIO=

# Redis
REDIS_URL=

# AI Vision Service (Internal Ollama Server)
AI_HOST=
AI_API_KEY=
DEEPSEEK_ENDPOINT=
QWEN_ENDPOINT=
DEEPSEEK_MODEL=
QWEN_MODEL=
REQUEST_TIMEOUT=
MAX_RETRY=

# Google Gemini Vision (Free Tier)
# Cara dapat API key:
#   1. Buka https://aistudio.google.com/apikey
#   2. Login dengan akun Google
#   3. Klik "Create API Key"
#   4. Copy key dan paste di bawah
# Free limit: 15 RPM, 1500 RPD — tidak butuh kartu kredit
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Groq Vision (Free Tier — Ultra Fast)
# Cara dapat API key:
#   1. Buka https://console.groq.com/keys
#   2. Daftar dengan email / Google / GitHub
#   3. Klik "Create API Key"
#   4. Copy key dan paste di bawah
# Free limit: 30 RPM, 14400 RPD — tidak butuh kartu kredit
GROQ_API_KEY=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Logging
LOG_LEVEL=
# LOG_FILE=
