# ─────────────────────────────────────────────────
# OCR Service — Environment Configuration Example
# Copy this file to .env.paddle and fill in your values.
# ─────────────────────────────────────────────────

# Application
APP_TITLE=<your_app_title>
APP_DESCRIPTION=REST API for OCR scanning — supports Indonesian documents (Raport, KTP, KK, Akta, KP) for PPDB web engine
APP_VERSION=<your_app_version>
DEBUG=<true_or_false>

# CORS
CORS_ORIGINS=<comma_separated_origins_or_*>
CORS_ALLOW_CREDENTIALS=<true_or_false>
CORS_ALLOW_METHODS=<comma_separated_methods_or_*>
CORS_ALLOW_HEADERS=<comma_separated_headers_or_*>

# File Upload
UPLOAD_DIR=<upload_directory_path>
MAX_UPLOAD_SIZE_MB=<max_size_in_mb>
ALLOWED_EXTENSIONS=<comma_separated_extensions>

# OCR Engine
OCR_LANG=<language_code>
OCR_DET_THRESH=<detection_threshold_0_to_1>
OCR_BOX_THRESH=<box_threshold_0_to_1>
OCR_USE_TEXTLINE_ORIENTATION=<true_or_false>
# Set true to warm up OCR engines on startup (eliminates first-request cold start)
OCR_WARMUP_ON_STARTUP=<true_or_false>

# Performance Tuning
# Enable Intel MKLDNN acceleration for CPU inference (recommended)
OCR_USE_MKLDNN=<true_or_false>
# Number of CPU threads for PaddlePaddle inference
OCR_CPU_THREADS=<number_of_threads>
# Enable GPU acceleration (requires paddlepaddle-gpu)
OCR_USE_GPU=<true_or_false>

# Image Processing
# Set false to skip denoising for high-quality digital PDFs
PREPROCESSING_DENOISE_ENABLED=<true_or_false>
# DPI multiplier when rendering PDF pages (e.g. 1.5 = 150 DPI)
PDF_RENDER_SCALE=<scale_multiplier>
# Maximum image width in pixels (larger images are downscaled)
IMAGE_MAX_WIDTH=<max_width_pixels>
# Maximum total pixel count (larger images are downscaled proportionally)
IMAGE_MAX_PIXELS=<max_total_pixels>

# AI Models (Qwen)
AI_HOST=<ai_host_url>
AI_API_KEY=<ai_api_key>
QWEN_ENDPOINT=<endpoint_path>
QWEN_MODEL=<model_name>
MINICPM_ENDPOINT=<endpoint_path>
MINICPM_MODEL=<model_name>
REQUEST_TIMEOUT=<timeout_in_seconds>
MAX_RETRY=<max_retry_count>

# Subject Matching
FUZZY_MATCH_THRESHOLD=<threshold_0_to_100>
Y_CLUSTER_TOLERANCE=<tolerance_in_pixels>
SCORE_ZONE_FALLBACK_RATIO=<ratio_0_to_1>

# Redis / Celery Task Queue (leave blank or remove to disable)
REDIS_URL=<redis_connection_url>

# PostgreSQL Database (for dynamic flags)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=secret

# Logging
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=<log_level>
# Uncomment to also write logs to a file:
# LOG_FILE=<path_to_log_file>
