# ─────────────────────────────────────────────────
# OCR Service — Environment Configuration Example
# Copy this file to .env.paddle and fill in your values.
# ─────────────────────────────────────────────────

# Application
APP_TITLE=
APP_DESCRIPTION=
APP_VERSION=
DEBUG=

# CORS
CORS_ORIGINS=
CORS_ALLOW_CREDENTIALS=
CORS_ALLOW_METHODS=
CORS_ALLOW_HEADERS=

# File Upload
UPLOAD_DIR=
MAX_UPLOAD_SIZE_MB=
ALLOWED_EXTENSIONS=

# OCR Engine
OCR_LANG=
OCR_DET_THRESH=
OCR_BOX_THRESH=
OCR_USE_TEXTLINE_ORIENTATION=
# Set to true to warm up the OCR engines on server startup.
# This eliminates first-request latency (~5-15s cold start) at the cost
# of slightly longer server boot time.
OCR_WARMUP_ON_STARTUP=

# Performance Tuning
# Enable Intel MKLDNN acceleration for CPU inference (recommended)
OCR_USE_MKLDNN=
# Number of CPU threads for PaddlePaddle inference
OCR_CPU_THREADS=
# Enable GPU acceleration (requires paddlepaddle-gpu)
OCR_USE_GPU=

# Image Processing
# Set to false to skip denoising for high-quality digital PDFs
PREPROCESSING_DENOISE_ENABLED=
# DPI multiplier when rendering PDF pages
PDF_RENDER_SCALE=
# Maximum image width in pixels (larger images are downscaled)
IMAGE_MAX_WIDTH=
# Maximum total pixel count (larger images are downscaled proportionally)
IMAGE_MAX_PIXELS=

# Subject Matching
FUZZY_MATCH_THRESHOLD=
Y_CLUSTER_TOLERANCE=
SCORE_ZONE_FALLBACK_RATIO=

# Redis (optional — leave blank to disable)
REDIS_URL=

# Logging
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=
# Uncomment to also write logs to a file:
# LOG_FILE=
